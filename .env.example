# === 매입 자동화 프로그램 환경변수 ===
# 이 파일을 복사해서 .env 로 이름 변경 후, 본인 키를 입력하세요.
# .env 파일은 GitHub에 올라가지 않습니다. (안전)

# 네이버 쇼핑 검색 API
NAVER_CLIENT_ID=여기에_네이버_클라이언트ID_입력
NAVER_CLIENT_SECRET=여기에_네이버_시크릿_입력

# Claude AI (이미지 자동 분류용)
ANTHROPIC_API_KEY=여기에_앤트로픽_API키_입력

# 쿠팡 OPEN API
COUPANG_ACCESS_KEY=여기에_쿠팡_액세스키_입력
COUPANG_SECRET_KEY=여기에_쿠팡_시크릿키_입력
COUPANG_VENDOR_ID=여기에_쿠팡_벤더ID_입력

# Google Gemini API
GEMINI_API_KEY=여기에_제미나이_API키_입력
